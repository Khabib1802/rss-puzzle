{
  "name": "rss-puzzle",
  "private": true,
  "homepage": "https://rolling-scopes-school.github.io/khabib1802-JSFE2025Q3/",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write src",
    "ci:format": "prettier --check src",
    "lint": "eslint src",
    "prepare": "cd .. && husky rss-puzzle/.husky",
    "deploy": "gh-pages -d dist --no-history"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "eslint"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(feat|fix|refactor|docs|style|chore)/RSS-PZ-\\d{2}_.*$|^rss-puzzle$"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "normalize-scss": "^8.0.0",
    "prettier": "^3.7.4",
    "sass": "^1.97.1",
    "typescript": "~5.9.3",
    "validate-branch-name": "^1.3.2",
    "vite": "^7.2.4"
  }
}
